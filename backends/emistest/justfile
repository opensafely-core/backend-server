set dotenv-load := true
set positional-arguments := true

# list available commands
default:
    @{{ just_executable() }} --list

# Clean up temporary files
clean:
    rm -rf .venv

# Install production requirements into and remove extraneous packages from venv
prodenv:
    uv sync --no-dev

# Install dev requirements into venv without removing extraneous packages
devenv:
    uv sync --inexact

upgrade-package package:
    uv lock --upgrade-package {{ package }}

# Upgrade all packages to the latest versions
upgrade-all:
    uv lock --upgrade

aws-configure:
  uv run aws configure

aws-session-token token:
  uv run aws configure set aws_session_token {{ token }}

packer-validate:
    uv run packer validate packer/emis-base.pkr.hcl

packer-init:
    uv run packer init packer/emis-base.pkr.hcl

_packer-build source args="":
    #!/usr/bin/env bash
    set -euo pipefail

    user=$(whoami)
    uv run packer build \
        -only "{{ source }}" \
        -var "build_version=0.0.1" \
        -var "user=$user" {{ args }} \
        packer/emis-base.pkr.hcl 


packer-build-vagrant *args: vagrant-clean
    just _packer-build vagrant.emis-test "{{ args }}"


packer-build-aws *args:
    just _packer-build amazon-ebs.emis-base "{{ args }}"
    

vagrant-clean:
    #!/usr/bin/env bash
    set -euo pipefail

    echo "Cleaning vagrant environment"
    if [ -d vagrant_box ]; then
        cd vagrant_box
        vagrant destroy 2>/dev/null || true
        cd ..
        rm -rf vagrant_box
    fi

    if [ -d vagrant_output ]; then
        rm -rf vagrant_output
    fi


# ssh to a running vagrant box as your user (defaults to vagrant user)
vagrant-ssh ssh_username="vagrant":
    #!/usr/bin/env bash
    cd vagrant_box
    vagrant ssh-config | grep -E -o 'Port (\d+)'
    sshport=$(vagrant ssh-config | grep -Po 'Port \K[^ ]+')
    ssh -p $sshport -o StrictHostKeyChecking=no {{ ssh_username }}@localhost


# Setup a new vagrant box after running packer-provision-vagrant
vagrant-run ssh_username="vagrant":
    #!/usr/bin/env bash
    set -euo pipefail

    mkdir vagrant_box
    cp vagrant_output/package.box ./vagrant_box
    cd vagrant_box
    vagrant box add --force test-emis-box package.box
    vagrant init test-emis-box
    
    vagrant up
    just vagrant-ssh {{ ssh_username }}


launch-instance ami_id="" security_group_id="sg-0edc735fb4f6f9393" instance_type="t3.micro":
    #!/usr/bin/env bash
    set -euo pipefail

    security_group="{{ security_group_id }}"
    ami_id={{ ami_id }}

    if [ "$security_group" = "sg-0edc735fb4f6f9393" ]; then
        echo "WARNING: Security group $security_group is overly permissive, do not use in production"
    fi

    if [ "$ami_id" = "" ]; then

        if [ ! -f packer/manifest.json ]; then
            echo 'ERROR: packer/manifest.json not found. Run `just packer-build-aws` or provide a specific ami-id'
            exit 1
        fi

        echo "Finding latest ami from packer/manifest.json"
        ami_id=$(jq -r '
            [.builds[] | select(.name == "emis-base" and .builder_type == "amazon-ebs")]
            | sort_by(.build_time)
            | last
            | if . == null then null else .artifact_id | split(":")[1] end
            ' packer/manifest.json)
    fi

    if [ -z "$ami_id" ] || [ "$ami_id" = "null" ]; then
        echo "ERROR: no emis-base build found in packer/manifest.json"
        exit 1
    fi

    echo "Using ami $ami_id"

    # EFS mount needs availability zone and subnet id. Our emis test EFS (fs-0f575eaf788fb79c9)
    # is in a single availability zone (1a), so retrieve just that subnet
    echo "Finding subnet for EFS mount target in availablity zone eu-west-1a"
    subnet_id=$(uv run aws ec2 describe-subnets \
        --region eu-west-1 \
        --filters "Name=vpc-id,Values=vpc-099c7f5528ff10c61" "Name=availability-zone,Values=eu-west-1a" \
        | jq -r '.Subnets[0].SubnetId')
    echo "Using subnet $subnet_id"

    name="$(whoami)-emis-test-$(date +%Y%m%d%H%M)"

    echo "Creating instance $name"

    # We pass user-data here (run-instances will base64 encode it for us), so we can override
    # the user-data baked into the AMI if we need to, without recreating the entire AMI
    instance_id=$(uv run aws ec2 run-instances \
      --image-id $ami_id \
      --count 1 \
      --instance-type {{ instance_type }} \
      --iam-instance-profile "Name=EmisInstanceRole" \
      --tag-specifications "ResourceType=instance,Tags=[{Key=Name,Value=$name}]" "ResourceType=volume,Tags=[{Key=Name,Value=$name}]" \
      --security-group-ids "$security_group" \
      --subnet-id "$subnet_id" \
      --block-device-mapping "[ { \"DeviceName\": \"/dev/sda1\", \"Ebs\": { \"VolumeSize\": 16 } } ]" \
      --user-data file://cloud-init-emis/user-data \
      | jq -r '.Instances[0].InstanceId'
    )

    # Find emistest elastic IP
    echo "Finding elastic IP"
    elastic_ip_address=$(uv run aws ec2 describe-addresses \
        --region eu-west-1 \
        --filters "Name=tag:Name,Values=emistest" \
        | jq -r .Addresses[0]
    )
    association_id=$(echo "$elastic_ip_address" | jq -r .AssociationId)
    allocation_id=$(echo "$elastic_ip_address" | jq -r .AllocationId)
    elastic_public_ip=$(echo "$elastic_ip_address" | jq -r .PublicIp)

    if [ "$association_id" != "null" ]; then
        # Dissociate the elastic IP from any current instance
        aws ec2 disassociate-address --association-id "$association_id"
    fi

    echo "Waiting for instance..."
    uv run aws ec2 wait instance-running --instance-ids "$instance_id" --region eu-west-1

    # Associate it with the new instance
    aws ec2 associate-address \
        --instance-id "$instance_id" \
        --allocation-id "$allocation_id"

    echo "Instance is running at $elastic_public_ip"
