BACKEND=emistest

OTEL_RESOURCE_ATTRIBUTES=rap.backend=emistest,backend=emistest

# this is essential for this backend
USING_DUMMY_DATA_BACKEND=True

DJANGO_ALLOWED_HOSTS=localhost,emistest.backends.opensafely.org

# Set backends explicitly rather than allowing it to use the defaults
# emistest isn't currently in the default list in jobrunner, and the agent
# needs its backend to be
BACKENDS=emistest

# Set the TEST env so Airlock continues to use the self-signed test certs
TEST=true
