BACKEND=emisv2
BASE_DOMAIN=emis-staging.opensafely.org

OTEL_RESOURCE_ATTRIBUTES=rap.backend=emisv2,backend=emisv2

# this is essential for this backend
USING_DUMMY_DATA_BACKEND=True

DJANGO_ALLOWED_HOSTS="localhost,emistest.backends.${BASE_DOMAIN}"

# Set backends explicitly rather than allowing it to use the defaults
# emistest isn't currently in the default list in jobrunner, and the agent
# needs its backend to be
BACKENDS=emisv2

# Set the TEST env so Airlock continues to use the self-signed test certs
TEST=true


# EFS mounted files
AIRLOCK_HOST_BASEDIR=/efs/airlock
HIGH_PRIVACY_STORAGE_BASE=/efs/high_privacy
MEDIUM_PRIVACY_STORAGE_BASE=/efs/medium_privacy
AIRLOCK_REPO_DIR=/efs/airlock/workdir/repos


# RAP Agent
CONTROLLER_TASK_API_ENDPOINT="https://controller.${BASE_DOMAIN}"
DOCKER_PROXY="docker-proxy.${BASE_DOMAIN}/opensafely-core"
GITHUB_PROXY_DOMAIN="github-proxy.${BASE_DOMAIN}"
