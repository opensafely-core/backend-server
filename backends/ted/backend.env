# Non-secret configuration specific to the TED backend
BACKEND=ted
# assure all telemetry is tagged with the backend it came from
# backend=tpp is for b/w compat, will be removed in future
OTEL_RESOURCE_ATTRIBUTES=rap.backend=ted

# these domains are place holders
# TODO: do we need them?
RELEASE_HOST=https://ted.backends.bennettoxford.org
DJANGO_ALLOWED_HOSTS=ted.backends.bennettoxford.org

# overrides for ted - we don't want to use the default controller
CONTROLLER_TASK_API_ENDPOINT=http://controller.ted.bennettoxford.org:8000
#CONTROLLER_TASK_API_ENDPOINT=https://controller.ted.bennettoxford.org
AIRLOCK_API_ENDPOINT=https://jobs.ted.bennettoxford.org
# Note: we're not using hte collector.
COLLECTOR_ADDRESS=https://collector.ted.bennettoxford.org
# no docker proxy for now
DOCKER_PROXY=ghcr.io/opensafely-core
# no github proxy for now
GITHUB_PROXY_DOMAIN=github.com
# allow bennett org repos
ALLOWED_GITHUB_ORGS=bennettoxford,opensafely
